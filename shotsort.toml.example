# Copy to `shotsort.toml` (or pass with --config) and edit. CLI flags override
# anything set here. Every key is optional.

# In-card destination root (must be on the same card, outside DCIM).
dest             = "/Volumes/SONY/Organized"

# photo (default) MOVES stills/clips out of DCIM. video COPIES camera video
# clips (Sony XAVC M4ROOT, AVCHD) out of the managed dirs, keeping originals;
# in video mode point SOURCE at the card root, not DCIM.
# mode           = "photo"

# With link = true the destination entries are relative symlinks into the source
# instead of byte copies (no data duplicated). Mac-only date view; see README.
# link           = false

# Which media to import: any of "raw", "jpeg", "video", or just ["all"].
types            = ["raw", "jpeg", "video"]

# Destination sub-folder and file-name templates.
# name_template supports {counter} — a per-date-folder sequence numbered by
# capture order. {counter:04} = pure 4-digit names (0000.ARW, 0001.ARW, ...);
# it is 0-based and CONTINUES across runs (a later batch appends 0005, 0006, ...
# rather than restarting), so re-running the same day never collides. A RAW+JPEG
# pair shares one number. The default {original} keeps the camera's filenames.
folder_template  = "{YYYY}/{YYYY}-{MM}-{DD}"
name_template    = "{original}"

# exif | mtime | exif-then-mtime
date_source      = "exif"
# skip | mtime | unknown-folder
on_missing_date  = "unknown-folder"
# rename | skip | overwrite
on_conflict      = "rename"
# name | hash | off
dedup            = "name"
# auto | size | hash | off
verify           = "auto"

clean_empty_dirs = false
jobs             = 1

# Fixed offset for UTC-sourced video timestamps, e.g. "+08:00".
# tz_offset      = "+08:00"
